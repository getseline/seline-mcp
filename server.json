{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.getseline/seline-mcp",
  "description": "Local MCP server for Seline Analytics API",
  "repository": {
    "url": "https://github.com/getseline/seline-mcp",
    "source": "github"
  },
  "version": "1.0.0",
  "title": "Seline",
  "websiteUrl": "https://seline.com",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@seline-analytics/mcp",
      "version": "1.0.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your API key for the service",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "YOUR_API_KEY"
        }
      ]
    }
  ]
}
